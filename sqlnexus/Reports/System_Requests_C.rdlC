  <Variables>
    <Variable Name="ReportTextColor">
      <Value>=Switch(Parameters!ContrastTheme.Value="Aquatic", "#FFFFFF",
Parameters!ContrastTheme.Value="Desert", "#3D3D3D",
Parameters!ContrastTheme.Value="None", "Black")</Value>
